<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.IpCamera" parent="Theme.Material3.Light.NoActionBar">

        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>

        <!-- iOS 26 Blue -->
        <item name="colorPrimary">@color/ios_blue</item>
        <item name="colorPrimaryVariant">@color/ios_blue_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Surface: glass white -->
        <item name="colorSurface">@color/glass_white</item>
        <item name="colorOnSurface">@color/ios_text</item>

        <!-- Background: gradient base -->
        <item name="android:colorBackground">@color/bg_base</item>

        <!-- Button style: pill -->
        <item name="materialButtonStyle">@style/Widget.IpCamera.Button.Pill</item>

        <!-- TextInputLayout: rounded glass -->
        <item name="textInputStyle">@style/Widget.IpCamera.TextInput</item>
    </style>

    <!-- Pill Button (primary filled) -->
    <style name="Widget.IpCamera.Button.Pill" parent="Widget.Material3.Button">
        <item name="cornerRadius">26dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">-0.01</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:minHeight">52dp</item>
    </style>

    <!-- Outlined pill button (secondary) -->
    <style name="Widget.IpCamera.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">26dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">-0.01</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="strokeColor">@color/glass_white_border</item>
        <item name="android:textColor">@color/ios_text</item>
    </style>

    <!-- Glass overlay button (dark, for use on video) -->
    <style name="Widget.IpCamera.Button.Glass" parent="Widget.Material3.Button">
        <item name="cornerRadius">26dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">-0.01</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">20dp</item>
        <item name="android:minHeight">44dp</item>
        <item name="backgroundTint">@color/glass_dark_btn</item>
        <item name="android:textColor">@color/white</item>
        <item name="strokeColor">@color/glass_white_border</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Rounded TextInputLayout -->
    <style name="Widget.IpCamera.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
        <item name="boxStrokeColor">@color/glass_white_border</item>
        <item name="boxBackgroundColor">@color/glass_white</item>
        <item name="helperTextTextColor">@color/ios_text_secondary</item>
    </style>

</resources>
